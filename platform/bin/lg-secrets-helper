#!/usr/bin/env php
<?php
/**
 * lg-secrets-helper — privileged secrets read/write for the Looth secrets dash.
 * RUNS AS ROOT via sudo. Confinement is this script + the ROOT-OWNED manifest:
 * it only touches manifest-declared locations, validates every id, logs actions.
 *
 * Credential model: each entry has a `locations` array (same value in 1+ places).
 * READ  = first present location.  WRITE = every location (twins never diverge).
 *
 * Usage (value on STDIN for `set`):
 *   lg-secrets-helper list            [--actor=NAME]
 *   lg-secrets-helper get    <id>     [--actor=NAME]
 *   lg-secrets-helper reveal <id>     [--actor=NAME]
 *   lg-secrets-helper set    <id>     [--actor=NAME]   # new value on STDIN
 *   lg-secrets-helper buckets         [--actor=NAME]   # live R2 inventory (CF API) or known fallback
 */

const MANIFEST = '/usr/local/lib/looth/lg-secrets-manifest.php';
const AUDIT    = '/var/log/lg-secrets-audit.log';

function out($a, int $code = 0): void { fwrite(STDOUT, json_encode($a, JSON_UNESCAPED_SLASHES) . "\n"); exit($code); }
function fail(string $m): void { out(['error' => $m], 1); }

function audit(string $actor, string $action, string $id, string $result): void {
    @file_put_contents(AUDIT, sprintf("%s actor=%s action=%s id=%s result=%s\n",
        gmdate('c'), $actor ?: '-', $action, $id, $result), FILE_APPEND | LOCK_EX);
    @chmod(AUDIT, 0600);
}

function fingerprint(?string $v): array {
    return ($v === null || $v === '')
        ? ['present' => false, 'len' => 0, 'last4' => '', 'sha8' => '']
        : ['present' => true, 'len' => strlen($v), 'last4' => substr($v, -4),
           'sha8' => substr(hash('sha256', $v), 0, 8)];
}

// ---- arg parse ----
$argv = $_SERVER['argv']; array_shift($argv);
$actor = '-'; $pos = [];
foreach ($argv as $a) {
    if (str_starts_with($a, '--actor=')) $actor = substr($a, 8); else $pos[] = $a;
}
$cmd = $pos[0] ?? ''; $id = $pos[1] ?? '';
$actor = preg_replace('/[^A-Za-z0-9 _.@-]/', '', $actor);

if (!is_file(MANIFEST)) fail('manifest not installed at ' . MANIFEST);
require MANIFEST;
$MAN = lg_secrets_manifest();
$ENV = lg_secrets_env();

// ===== per-location backends =====
function loc_read(array $L): ?string {
    switch ($L['kind']) {
        case 'env_kv':    return env_kv_read($L['path'], $L['key']);
        case 'rclone':    return rclone_read($L['path'], $L['remote'], $L['field']);
        case 'wp_option': return wp_option_read($L['option']);
        case 'file':      return is_readable($L['path']) ? rtrim(file_get_contents($L['path']), "\r\n") : null;
    }
    return null;
}
function loc_write(array $L, string $val): void {
    switch ($L['kind']) {
        case 'env_kv':    env_kv_write($L['path'], $L['key'], $val); return;
        case 'rclone':    rclone_write($L['path'], $L['remote'], $L['field'], $val); return;
        case 'wp_option': wp_option_write($L['option'], $val); return;
        case 'file':      atomic_put($L['path'], $val . "\n"); return;
    }
    fail('unknown kind: ' . $L['kind']);
}
function loc_where(array $L): string {
    switch ($L['kind']) {
        case 'env_kv':    return basename($L['path']) . ':' . $L['key'];
        case 'rclone':    return 'rclone[' . $L['remote'] . ']:' . $L['field'];
        case 'wp_option': return 'wp_option:' . $L['option'];
        case 'file':      return $L['path'];
    }
    return $L['kind'];
}

// ---- entry-level read: first present location ----
function entry_read(array $e): ?string {
    foreach ($e['locations'] as $L) { $v = loc_read($L); if ($v !== null && $v !== '') return $v; }
    return null;
}

// ---- env_kv ----
function env_kv_read(string $path, string $key): ?string {
    if (!is_readable($path)) return null;
    foreach (file($path, FILE_IGNORE_NEW_LINES) as $line)
        if (preg_match('/^\s*' . preg_quote($key, '/') . '\s*=(.*)$/', $line, $m)) return trim($m[1], " \t\"'");
    return null;
}
function env_kv_write(string $path, string $key, string $val): void {
    $lines = is_file($path) ? file($path, FILE_IGNORE_NEW_LINES) : []; $done = false;
    foreach ($lines as $i => $line)
        if (preg_match('/^\s*' . preg_quote($key, '/') . '\s*=/', $line)) { $lines[$i] = $key . '=' . $val; $done = true; break; }
    if (!$done) $lines[] = $key . '=' . $val;
    atomic_put($path, implode("\n", $lines) . "\n");
}

// ---- rclone INI ----
function rclone_read(string $path, string $remote, string $field): ?string {
    if (!is_readable($path)) return null; $in = false;
    foreach (file($path, FILE_IGNORE_NEW_LINES) as $line) {
        if (preg_match('/^\s*\[(.+?)\]\s*$/', $line, $m)) { $in = ($m[1] === $remote); continue; }
        if ($in && preg_match('/^\s*' . preg_quote($field, '/') . '\s*=(.*)$/', $line, $m)) return trim($m[1]);
    }
    return null;
}
function rclone_write(string $path, string $remote, string $field, string $val): void {
    if (!is_file($path)) fail('rclone conf missing: ' . $path);
    $lines = file($path, FILE_IGNORE_NEW_LINES); $in = false; $done = false; $start = -1;
    foreach ($lines as $i => $line) {
        if (preg_match('/^\s*\[(.+?)\]\s*$/', $line, $m)) { $in = ($m[1] === $remote); if ($in) $start = $i; continue; }
        if ($in && preg_match('/^\s*' . preg_quote($field, '/') . '\s*=/', $line)) { $lines[$i] = $field . ' = ' . $val; $done = true; break; }
    }
    if (!$done) { if ($start < 0) fail("rclone remote [$remote] not found"); array_splice($lines, $start + 1, 0, [$field . ' = ' . $val]); }
    atomic_put($path, implode("\n", $lines) . "\n");
}

// ---- wp_option via wp-cli as the WP user (no root for the DB) ----
function wp_option_read(string $option): ?string { [$c, $o] = wp(['option', 'get', $option]); return $c === 0 ? rtrim($o, "\n") : null; }
function wp_option_write(string $option, string $val): void { [$c, $o] = wp(['option', 'update', $option, $val]); if ($c !== 0) fail('wp option update failed: ' . trim($o)); }
function wp(array $args): array {
    global $ENV;
    $cmd = 'sudo -u ' . escapeshellarg($ENV['LG_WP_USER'] ?? 'looth-dev') . ' -- wp --path=' . escapeshellarg($ENV['LG_WP_PATH'] ?? '/var/www/dev');
    foreach ($args as $a) $cmd .= ' ' . escapeshellarg($a);
    exec($cmd . ' 2>&1', $lines, $code); return [$code, implode("\n", $lines)];
}

// ---- atomic write preserving existing owner/group/mode ----
function atomic_put(string $path, string $content): void {
    clearstatcache(); $exists = is_file($path);
    $uid = $exists ? fileowner($path) : null; $gid = $exists ? filegroup($path) : null;
    $mode = $exists ? (fileperms($path) & 0777) : 0640;
    $tmp = $path . '.lgsec.' . getmypid();
    if (file_put_contents($tmp, $content) === false) fail('write failed: ' . $path);
    @chmod($tmp, $mode); if ($uid !== null) @chown($tmp, $uid); if ($gid !== null) @chgrp($tmp, $gid);
    if (!rename($tmp, $path)) { @unlink($tmp); fail('rename failed: ' . $path); }
}

// ---- Cloudflare REST API (live bucket inventory) ----
function cf_token(): ?string {
    global $MAN; return isset($MAN['cf-api-token']) ? entry_read($MAN['cf-api-token']) : null;
}
function cf_get(string $token, string $path): ?array {
    $url = 'https://api.cloudflare.com/client/v4' . $path;
    $cmd = 'curl -fsS --max-time 20 -H ' . escapeshellarg('Authorization: Bearer ' . $token)
         . ' -H ' . escapeshellarg('Content-Type: application/json') . ' ' . escapeshellarg($url) . ' 2>/dev/null';
    exec($cmd, $lines, $code); if ($code !== 0) return null;
    $j = json_decode(implode("\n", $lines), true); return is_array($j) ? $j : null;
}

// ===== commands =====
switch ($cmd) {

case 'list':
    $rows = [];
    foreach ($MAN as $key => $e) {
        $primary = entry_read($e); $fp = fingerprint($primary);
        $locs = []; $shas = [];
        foreach ($e['locations'] as $L) {
            $v = loc_read($L); $f = fingerprint($v);
            $locs[] = ['where' => loc_where($L), 'present' => $f['present'], 'last4' => $f['last4'], 'sha8' => $f['sha8']];
            if ($f['present']) $shas[$f['sha8']] = true;
        }
        $rows[] = [
            'id' => $key, 'label' => $e['label'], 'group' => $e['group'], 'sensitivity' => $e['sensitivity'],
            'writable' => (bool) $e['writable'], 'note' => $e['note'] ?? '', 'buckets' => $e['buckets'] ?? [],
            'locations' => $locs, 'divergent' => count($shas) > 1,
        ] + $fp;
    }
    out(['secrets' => $rows]);

case 'get':
    if (!isset($MAN[$id])) fail('unknown id');
    out(['id' => $id] + fingerprint(entry_read($MAN[$id])));

case 'reveal':
    if (!isset($MAN[$id])) fail('unknown id');
    $v = entry_read($MAN[$id]); audit($actor, 'reveal', $id, $v === null ? 'absent' : 'ok');
    out(['id' => $id, 'value' => (string) $v, 'present' => $v !== null]);

case 'set':
    if (!isset($MAN[$id])) fail('unknown id');
    if (empty($MAN[$id]['writable'])) { audit($actor, 'set', $id, 'denied-readonly'); fail('not writable'); }
    $val = stream_get_contents(STDIN); if ($val === false) fail('no value on stdin');
    $val = rtrim($val, "\r\n"); if ($val === '') { audit($actor, 'set', $id, 'rejected-empty'); fail('empty value rejected'); }
    $wrote = [];
    foreach ($MAN[$id]['locations'] as $L) { loc_write($L, $val); $wrote[] = loc_where($L); }
    audit($actor, 'set', $id, 'ok len=' . strlen($val) . ' locs=' . count($wrote));
    out(['id' => $id, 'saved' => true, 'wrote' => $wrote] + fingerprint($val));

case 'buckets':
    $known = lg_secrets_buckets();
    $token = cf_token();
    if (!$token) { out(['available' => false, 'source' => 'known', 'buckets' => $known]); }
    $acct = lg_secrets_r2_account();
    $list = cf_get($token, "/accounts/$acct/r2/buckets");
    if (!$list || empty($list['success'])) {
        $err = $list['errors'][0]['message'] ?? 'CF API call failed';
        out(['available' => false, 'source' => 'known', 'error' => $err, 'buckets' => $known]);
    }
    // index known meta by name
    $meta = []; foreach ($known as $b) $meta[$b['name']] = $b;
    $buckets = [];
    foreach ($list['result']['buckets'] ?? [] as $b) {
        $name = $b['name'] ?? '';
        $usage = cf_get($token, "/accounts/$acct/r2/buckets/" . rawurlencode($name) . "/usage");
        $u = ($usage && !empty($usage['success'])) ? ($usage['result'] ?? []) : [];
        $buckets[] = [
            'name' => $name,
            'created' => $b['creation_date'] ?? '',
            'count' => $u['objectCount'] ?? ($u['object_count'] ?? null),
            'size'  => $u['payloadSize']  ?? ($u['metadataSize'] ?? null),
            'env'   => $meta[$name]['env']  ?? '', 'cred' => $meta[$name]['cred'] ?? '',
            'verified' => $meta[$name]['verified'] ?? false,
        ];
    }
    audit($actor, 'buckets', '-', 'ok n=' . count($buckets));
    out(['available' => true, 'source' => 'cloudflare', 'account' => $acct, 'buckets' => $buckets]);

default:
    fail('usage: list | get <id> | reveal <id> | set <id> | buckets  [--actor=NAME]');
}
