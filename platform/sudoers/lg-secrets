# Looth secrets dashboard — installed to /etc/sudoers.d/lg-secrets (0440) by
# platform/bin/install-secrets-bridge.sh, which substitutes @WPUSER@ from
# /etc/looth/env (LG_WP_USER). The WP FPM user may run ONLY the root-owned
# helper — nothing else. The helper itself confines what that root can touch.
@WPUSER@ ALL=(root) NOPASSWD: /usr/local/sbin/lg-secrets-helper
