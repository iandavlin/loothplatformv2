# env.template — the canonical /etc/looth/env contract for loothplatformv2
#
# Policy: docs/atlas/REPO-MANDATE.md (env-file hygiene). This file documents EVERY
# box-varying key. The real /etc/looth/env is box-local (root:root 644, NOT in git);
# copy this, fill per box. Promotion dev2 -> live = change values HERE only, zero code.
# Apps read keys via /srv/lg-shared/lg-env.php (lg_env()) — never hardcode a value.
#
# Format:  KEY=<dev2 example>            # who uses it | live: <live example>

# --- core identity / host ---
LG_ENV=dev2                              # platform-wide env name | live: live
LG_PUBLIC_HOST=dev2.loothgroup.com       # WP siteurl/home + every app's URLs | live: loothgroup.com
LG_GATE_COOKIE=loothdev_auth             # dev cookie gate (off at cut) | live: (gate off)

# --- WordPress ---
LG_WP_PATH=/var/www/dev                  # WP root | live: <live docroot>
LG_WP_USER=looth-dev                     # web / FPM user | live: looth-live

# --- databases (NAMES only; creds are SECRETS — see below) ---
LG_MYSQL_DB=looth_import                  # WP DB        | live: <live WP DB>
LG_MYSQL_BILLING_DB=lg_membership         # billing DB
LG_PG_DB=looth                            # postgres: forums / discovery / poller
LG_PG_DB_PROFILE=profile_app              # postgres: profile-app

# --- app public host ---
# TARGET (REPO-MANDATE §2): these should all DERIVE from LG_PUBLIC_HOST.
# DEBT (SYSTEM-MAP §3): today they are pinned per FPM pool, NOT read from this file —
#   LG_ARCHIVE_POC_PUBLIC_HOST, LG_BB_MIRROR_PUBLIC_HOST, LG_EVENTS_PUBLIC_HOST,
#   LG_MEMBERSHIP_PUBLIC_HOST  (in archive-poc.conf, bb-mirror.conf, events.conf,
#   membership.conf, looth-dev.conf x2). Until consolidated, set them = LG_PUBLIC_HOST.

# --- SECRETS: keys listed, VALUES never in git. Provision per box; pointer = where it lives. ---
# /etc/looth/jwt-private.pem           JWT signing               -> provisioned at standup
# /etc/looth/cf-api-token              R2 / Cloudflare read      -> lg-secrets-helper
# /etc/lg-events-db                    events RO MySQL creds     -> box-local 640
# sheets-bot WP Application Password   Sheet→WP bridge           -> Google Script Properties; bin/provision-sheets-bot.sh
# Patreon / Stripe poller tokens       poller                    -> secrets manager
