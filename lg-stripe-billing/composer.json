{
    "name": "loothgroup/lg-stripe-billing",
    "description": "Standalone Stripe membership billing service for loothgroup.com",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "stripe/stripe-php": "^14.0",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "LGSB\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LGSB\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
